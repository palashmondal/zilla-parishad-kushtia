{
  "name": "zpkushtia-tools",
  "version": "2.0.0",
  "description": "ZP Kushtia Tools - জেলা পরিষদ, কুষ্টিয়া",
  "main": "src/server.js",
  "scripts": {
    "build:css": "npx tailwindcss -i ./public/styles.css -o ./public/output.css",
    "watch:css": "npx tailwindcss -i ./public/styles.css -o ./public/output.css --watch",
    "start": "node src/server.js",
    "dev": "npm run watch:css & nodemon src/server.js",
    "legacy": "node server.js",
    "test": "curl http://localhost:3000/api/health"
  },
  "keywords": [
    "zilla-parishad",
    "kushtia",
    "bangladesh",
    "scholarship",
    "humanitarian-aid",
    "project-management"
  ],
