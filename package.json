  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "mysql2": "^3.6.5",
    "string-similarity": "^4.0.4"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "nodemon": "^3.0.2",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19"
  }
